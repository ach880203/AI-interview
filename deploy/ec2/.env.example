# EC2 운영 환경변수 예시
# 이 파일은 예시이며, 실제 운영값은 GitHub Actions 시크릿(EC2_APP_ENV_FILE)로 관리합니다.
# 한글 깨짐 방지를 위해 반드시 UTF-8로 저장합니다.

# 이미지 태그는 GitHub Actions가 배포 때마다 최신 SHA로 덮어씁니다.
BACKEND_IMAGE=
AI_SERVER_IMAGE=
ECR_REGISTRY=

# DB
MARIADB_DATABASE=ai_interview
DB_USERNAME=root
DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_me
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# Python AI
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o

# 프론트 배포 주소를 반드시 실제 CloudFront 또는 커스텀 도메인으로 맞춰야 CORS가 안전합니다.
CORS_ORIGINS=https://your-frontend-domain.com

# 카카오 OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-frontend-domain.com/auth/kakao/callback

# PortOne
PORTONE_SECRET_KEY=

# 백엔드/AI 서버 동작 옵션
AI_SERVICE_MOCK=false
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_SQL=WARN
LOG_LEVEL_SQL_BIND=WARN
