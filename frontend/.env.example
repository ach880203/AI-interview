# ── React 프론트엔드 환경 변수 ────────────────────────────────
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# Vite 환경변수는 VITE_ 접두사가 필요합니다.

# 백엔드 API 주소 (기본값: 로컬 Spring Boot)
VITE_API_BASE_URL=http://localhost:8080

# 카카오 OAuth client_id(REST API 키)
# 로그인 인가 URL의 client_id로 사용되므로 JavaScript 키와 혼동하지 않도록 이름을 분리합니다.
VITE_KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# PortOne 결제 연동 (https://admin.portone.io)
# 비어 있으면 모의 결제 흐름으로 동작합니다 (로컬 개발용)
VITE_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
