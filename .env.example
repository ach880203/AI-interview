# ── Docker Compose 전체 서비스 환경 변수 ──────────────────────
# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요.
# .env 파일은 절대 git에 커밋하지 마세요.

# ── MariaDB ───────────────────────────────────────────────────
# 데이터베이스 비밀번호 (mariadb 컨테이너, Spring Boot가 공통으로 사용)
DB_PASSWORD=your_strong_db_password_here

# ── Spring Boot 백엔드 ────────────────────────────────────────
# JWT 서명 키 — 최소 32바이트 이상의 랜덤 Base64 문자열
# 생성 방법: openssl rand -base64 48
JWT_SECRET=your_base64_encoded_jwt_secret_here

# 프론트엔드 도메인 (CORS 허용 오리진)
# 로컬: http://localhost / 운영: https://your-domain.com
FRONTEND_URL=http://localhost

# ── React 프론트엔드 (빌드 타임 설정) ────────────────────────
# 백엔드 API 주소 (Vite 빌드 시 번들에 포함됨)
# 로컬 Docker Compose: http://localhost:8080
# 운영: https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:8080

# ── Python AI 서버 ────────────────────────────────────────────
# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# 사용할 GPT 모델 (기본값: gpt-4o)
MODEL_NAME=gpt-4o
