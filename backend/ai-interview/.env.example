# Spring Boot 환경변수 예시 파일입니다.
# 이 파일을 복사해서 .env로 만든 뒤 실제 값을 채워 사용합니다.
# .env 파일은 git에 커밋하지 않습니다.

# 데이터베이스
DB_URL=jdbc:mariadb://localhost:3308/ai_interview_chang?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Seoul
DB_USERNAME=aiapp
DB_PASSWORD=your_strong_password_here

# JWT
# Base64 문자열을 권장하지만, 현재 코드는 일반 문자열도 안전하게 읽습니다.
JWT_SECRET=your_base64_encoded_secret_here
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# AI 서버
AI_SERVER_URL=http://localhost:8000

# PortOne 결제
PORTONE_SECRET_KEY=your_portone_secret_key_here

# 카카오 OAuth
# KAKAO_CLIENT_ID는 카카오 OAuth authorize URL의 client_id로 사용합니다.
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
